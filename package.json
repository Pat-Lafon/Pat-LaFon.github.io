{
	"name": "pat-lafon-github-io",
	"version": "1.0.0",
	"description": "Personal website and blog for Patrick LaFontaine, plus standalone hiragana and meditation PWAs.",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "npx @11ty/eleventy",
		"build-nocolor": "cross-env NODE_DISABLE_COLORS=1 npx @11ty/eleventy",
		"build-ghpages": "npx @11ty/eleventy --pathprefix=/",
		"start": "npx @11ty/eleventy --serve --quiet",
		"start-ghpages": "npx @11ty/eleventy --pathprefix=/ --serve --quiet",
		"debug": "cross-env DEBUG=Eleventy* npx @11ty/eleventy",
		"debugstart": "cross-env DEBUG=Eleventy* npx @11ty/eleventy --serve --quiet",
		"benchmark": "cross-env DEBUG=Eleventy:Benchmark* npx @11ty/eleventy",
		"lint": "eslint .",
		"test": "npm run lint && node hiragana/storage-budget.test.js && node hiragana/vendor/check-updates.js && node hiragana/vendor/import-scan.test.js && npm run build && node _config/sw/offline.test.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Pat-Lafon/Pat-LaFon.github.io.git"
	},
	"author": {
		"name": "Patrick LaFontaine",
		"url": "https://pat-lafon.github.io/"
	},
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"bugs": {
		"url": "https://github.com/Pat-Lafon/Pat-LaFon.github.io/issues"
	},
	"homepage": "https://pat-lafon.github.io/",
	"devDependencies": {
		"@11ty/eleventy": "^3.1.5",
		"@11ty/eleventy-img": "^6.0.4",
		"@11ty/eleventy-navigation": "^1.0.5",
		"@11ty/eleventy-plugin-rss": "^3.0.0",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
		"@eslint/js": "^10.0.1",
		"@tailwindcss/cli": "^4.3.0",
		"cross-env": "^10.1.0",
		"esbuild": "^0.28.0",
		"eslint": "^10.3.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"globals": "^17.6.0",
		"htm": "3.1.1",
		"luxon": "^3.7.2",
		"prismjs": "^1.29.0",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"scheduler": "0.27.0",
		"tailwindcss": "^4.3.0",
		"workbox-build": "^7.4.1",
		"workbox-cacheable-response": "^7.3.0",
		"workbox-expiration": "^7.3.0",
		"workbox-precaching": "^7.3.0",
		"workbox-routing": "^7.3.0",
		"workbox-strategies": "^7.3.0",
		"zod": "^4.4.3",
		"zod-validation-error": "^5.0.0"
	},
	"dependencies": {
		"@zachleat/heading-anchors": "^1.0.5"
	}
}
